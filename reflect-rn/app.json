{
  "expo": {
    "name": "Reflect",
    "slug": "reflect-rn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#e8f4fd"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.reflect.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#e8f4fd"
      },
      "package": "com.reflect.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-system-ui"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "reflect"
  }
}
